# SciToday 后端 —— Linux 云服务器环境变量
# 由 systemd 的 EnvironmentFile 加载。改完需要: sudo systemctl restart scitoday
#
# 说明: 这里的每一项都对应代码里实际读取的 RSSAI_* 变量(已逐一核对)。
# 只列上云真正需要设的; 其余变量代码里都有合理默认值, 不设即用默认。

# ---- 运行环境 ----
# 决定平台分支。云上 Linux 必须显式设为 pc, 否则会被当成 Termux(安卓)去找
# /storage/emulated/0 这种不存在的路径。
RSSAI_RUNTIME=pc

# ---- 监听地址/端口 ----
# 前面有 Nginx 反代时, 后端只监听本机回环即可, 不要直接暴露公网。
# (若暂时不用 Nginx、想让后端直接对外, 才改成 0.0.0.0 —— 但那样没有 HTTPS, 不推荐)
RSSAI_SERVER_HOST=127.0.0.1
RSSAI_SERVER_PORT=5201
RSSAI_WAITRESS_THREADS=8
# Waitress 只信任同机 Nginx 的代理头。禁止使用 *；后端也必须继续只监听 loopback。
RSSAI_TRUSTED_PROXY=127.0.0.1

# ---- 数据目录(最关键) ----
# 你的 68 个数据库 + 11 个租户都在这里。必须指向服务器上放 ServerData 的绝对路径。
# 部署时把包里的 ServerData/ 放到下面这个位置(或改成你实际的路径)。
RSSAI_SERVER_DATA_DIR=/opt/scitoday/ServerData

# ---- 可信 Host(上云最容易漏的一项!) ----
# 代码默认只信任 127.0.0.1 / localhost。经 Nginx 反代进来的请求 Host 是你的域名,
# 不在此列表就会被 Werkzeug 拒绝(HTTP 400 Bad Request), 控制台和 App 全都打不开。
# 逗号分隔, 填你的真实域名。前缀 . 可通配子域名(如 .scitoday-chd.xyz)。
RSSAI_TRUSTED_HOSTS=cn.scitoday.scitoday-chd.xyz,scitoday.scitoday-chd.xyz,scitoday-cn.scitoday-chd.xyz

# ---- 上传大小限制(与 Nginx 的 client_max_body_size 64m 保持一致) ----
RSSAI_MAX_REQUEST_BYTES=67108864
RSSAI_MAX_UPLOAD_CHUNK_BYTES=8388608
RSSAI_MAX_UPLOAD_TOTAL_BYTES=67108864

# ---- 后台任务协调器(有默认值, 一般不用改) ----
# RSSAI_JOB_WORKERS=2
# RSSAI_JOB_QUEUE_SIZE=8
# RSSAI_JOB_SCAN_SECONDS=30
# RSSAI_JOB_LEASE_SECONDS=3600

# ---- Operator 令牌 ----
# 运维级接口(建/删租户、看日志、改设置)需要 operator token。
# 默认从 <数据目录>/control/operator_token 文件读取(你的 ServerData 里若已有, 会一起带上云)。
# 如果想用环境变量覆盖, 取消下面注释并填入; 否则保持注释、用文件里的即可。
# RSSAI_OPERATOR_TOKEN=

# ---- 说明: 不要在这里放 DeepSeek API Key ----
# AI key 由 config.json 的 ai.api_key 提供, 不是环境变量。config.json 已在包内。
